# Project name (used as the Docker image name)
PROJECT_NAME=ros2_docker_ws

# Workspace directory name (relative to /home/ros/)
WORKSPACE_NAME=ros2_ws

# ROS Distribution
DOCKER_ROS_DISTRO=jazzy

# Type of installation. Available variables:
# BASE_IMAGE=hardware
# BASE_IMAGE=gazebo
BASE_IMAGE=gazebo-cuda

# Default ROS_DOMAIN_ID
DOCKER_ROS_DOMAIN_ID=0

# RMW implementation (comment out to use ROS default - FastDDS)
# DOCKER_RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
DOCKER_RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# GPU ID to use
GPU_ID=0

# Set VirtualGL version
VIRTUALGL_VER=3.1.4

DOCKER_DISPLAY=:200